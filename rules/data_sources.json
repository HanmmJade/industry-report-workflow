  "sources_by_credibility": {
    "A": [
      "政府官方机构（国家能源局、国家统计局等）",
      "行业协会官方发布（CABIA、CAAM、CPIA等）",
      "国际权威机构（BNEF、IEA、SNE Research等）",
      "顶级学术期刊（Nature、Science等）",
      "交易所官方信息（上交所、港交所等）",
      "上市公司公告（经审计）"
    ],
    "B": [
      "权威咨询机构（InfoLink、Mysteel等）",
      "券商研究报告（中信证券、国泰君安等）",
      "权威财经媒体（财联社、界面新闻等）",
      "行业权威媒体（激光制造网、Ofweek等）"
    ],
    "C": [
      "普通行业媒体",
      "公众号、自媒体",
      "专家博客"
    ],
    "D": [
      "来源不明",
      "传闻信息",
      "无法验证的数据"
    ]
  },
  
  "data_type_definitions": {
    "历史数据": {
      "description": "基于实际发生的统计数据",
      "特征": [
        "发布日期在数据周期之后",
        "数据精确到小数",
        "通常包含'实际/统计/累计'等词"
      ]
    },
    "预测值": {
      "description": "基于模型或判断的未来预估",
      "特征": [
        "发布日期可能在数据周期之中或之前",
        "通常包含'预计/预期/预测/estimate/forecast'",
        "数据可能较整"
      ],
      "标注要求": "必须显式标注'⚠️预测值'"
    },
    "估算值": {
      "description": "基于部分数据的推算",
      "特征": [
        "通常无法找到完整数据来源",
        "可能使用'约/大概/估计'等词"
      ],
      "标注要求": "必须显式标注'⚠️估算值'"
    }
  },
  
  "credibility_upgrade_rules": [
    {
      "from": "B",
      "to": "A",
      "condition": "获得2个及以上A级来源验证",
      "example": "国家能源局数据 + 银河证券研报"
    },
    {
      "from": "C",
      "to": "B",
      "condition": "获得1个B级或A级来源验证",
      "example": "媒体报道 + 上市公司公告确认"
    }
  ],
  
  "credibility_degrade_rules": [
    {
      "from": "A/B",
      "to": "D",
      "condition": "多源数据冲突>10%且无法判断",
      "example": "InfoLink vs Mysteel数据差异20%"
    },
    {
      "from": "A",
      "to": "C",
      "condition": "预测值误标为实际值",
      "example": "Mysteel预测数据标注为实际值"
    },
    {
      "from": "A/B",
      "to": "B/C",
      "condition": "发布时间异常",
      "example": "3月10日发布的文章作为3月实际数据"
    }
  ]
}
